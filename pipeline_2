pipeline {
    agent any

    environment {
        // Define versions or paths here for easy maintenance
        PYTHON_CMD = 'python3'
    }

    stages {
        stage('Initialize Environment') {
            steps {
                script {
                    // Check if python3 exists; if not, try to install it
                    def pythonExists = sh(script: 'command -v ${PYTHON_CMD}', returnStatus: true) == 0
                    
                    if (!pythonExists) {
                        echo "Python not found! Attempting to install..."
                        // Attempting installation (assuming Debian/Ubuntu based runner)
                        // Note: This requires the Jenkins user to have appropriate permissions
                        sh 'sudo apt-get update && sudo apt-get install -y python3'
                    } else {
                        echo "Python already installed."
                    }
                }
            }
        }

        stage('Test Execution') {
            steps {
                echo "Running application tests..."
                sh '''
                    ${PYTHON_CMD} --version
                    ${PYTHON_CMD} -c "print('Pipeline is successfully running Python code!')"
                '''
            }
        }

        stage('Cleanup') {
            steps {
                echo "Cleaning up workspace..."
                sh 'rm -rf ./temp_build_files'
            }
        }
    }

    post {
        failure {
            echo "Pipeline failed. Check the logs for missing dependencies."
        }
        success {
            echo "Pipeline finished successfully!"
        }
    }
}
